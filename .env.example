# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then Settings → API.
# Until these are set the app runs in demo mode with in-memory data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for privileged jobs (settlement runs, OTA pushes).
# NEVER expose this to the browser and never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments ────────────────────────────────────────────────────────────────
# Each provider adapter reads its own credentials. Leave blank to keep the
# simulated adapter active for that provider.
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
INNBUCKS_MERCHANT_ID=
INNBUCKS_API_KEY=

# ─── EcoCash Instant Payment (EIP) ───────────────────────────────────────────
# Sandbox: https://developers.ecocash.co.zw — request sandbox access to get
# a username/password (HTTP Basic Auth). Server-only; never NEXT_PUBLIC.
# Set NEXT_PUBLIC_ECOCASH_ENABLED=true to switch the app from the simulated
# EcoCash adapter to the live rail (requires a rebuild).
ECOCASH_API_BASE_URL=https://developers.ecocash.co.zw/sandbox/payment/v1
ECOCASH_API_USERNAME=
ECOCASH_API_PASSWORD=
ECOCASH_MERCHANT_CODE=
ECOCASH_MERCHANT_PIN=
ECOCASH_MERCHANT_NUMBER=
ECOCASH_TERMINAL_ID=
ECOCASH_MERCHANT_NAME=SmartPilater
ECOCASH_SUPER_MERCHANT_NAME=ECOCASH
ECOCASH_LOCATION=Harare
NEXT_PUBLIC_ECOCASH_ENABLED=false

# ─── App ─────────────────────────────────────────────────────────────────────
# Public origin used inside receipt verification QRs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
